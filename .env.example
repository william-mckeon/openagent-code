# =============================================================================
# openagent-code - environment variables (example)
# =============================================================================
#
# Copy this file to `.env` and fill in real values BEFORE running the agent.
# NEVER commit `.env`.
#
#     cp .env.example .env
#     # then edit .env
#
# Every variable name here matches the os.environ.get() calls in src/config.py
# and the ENV defaults in docker/code/Dockerfile. Every value has a default in
# src/config.py if left unset, except the model endpoint, which you must point
# at your own provider.
# =============================================================================


# -----------------------------------------------------------------------------
# Model gateway — the swappable boundary                          (src/config.py)
# -----------------------------------------------------------------------------
#
# CODE_MODEL is the LiteLLM model string. CODE_API_BASE is the OpenAI-compatible
# endpoint URL. Switching providers is an edit HERE, never a code change.
#
#   Self-hosted vLLM / RunPod (gpt-oss-120b):
#     CODE_MODEL=openai/gpt-oss-120b
#     CODE_API_BASE=https://<your-pod>-8000.proxy.runpod.net/v1
#
#   AWS Bedrock (leave CODE_API_BASE empty; uses AWS_* credentials below):
#     CODE_MODEL=bedrock/openai.gpt-oss-120b-1:0
#     CODE_API_BASE=

CODE_MODEL=openai/gpt-oss-120b
CODE_API_BASE=http://localhost:8000/v1

# Key for the endpoint. For self-hosted vLLM this is the value passed to
# --api-key (or "EMPTY" if none was set). Leave as-is for Bedrock and set the
# AWS_* vars instead.
CODE_API_KEY=EMPTY

# Sampling temperature for the agent loop. Lower = more deterministic edits.
CODE_TEMPERATURE=0.2

# gpt-oss reasoning depth: low | medium | high (sent as reasoning_effort). Higher =
# the model deliberates more before answering — helps a weaker model (e.g. 20b) actually
# investigate / call tools instead of confabulating. Empty = use the endpoint default.
CODE_REASONING_EFFORT=

# Retry transient model failures (connection/timeout/5xx) and dropped tool calls
# (empty response from a worker missing the tool-call parser), with backoff. Makes
# a flaky / intermittent endpoint usable. 0 = no retries.
CODE_MODEL_RETRIES=3

# --- cold starts (scale-to-zero serverless) ---
# Read timeout (seconds) for a single model call. Generous on purpose: a
# scale-to-zero worker cold-starts on its first call after idle (tens of seconds),
# and a short timeout would abort the spin-up. Mirrors openagent-infra (600s).
CODE_REQUEST_TIMEOUT=600
# Before the first task, send a throwaway tool-call probe and wait until the worker
# returns a real tool_call (warm + parser active), up to CODE_WARMUP_BUDGET seconds.
# Stops the first real task from eating the cold start. false = skip; no-op for
# Bedrock (empty CODE_API_BASE).
CODE_WARMUP=true
CODE_WARMUP_BUDGET=600

# How the model invokes tools:
#   native — OpenAI tool-calling. Default. Requires the serving stack to parse tool
#            calls; for gpt-oss on vLLM, launch the worker with
#            --enable-auto-tool-choice --tool-call-parser.
#   json   — prompt-based fallback, parsed by the harness. Works on ANY
#            OpenAI-compatible endpoint with no server tool-parser, but is brittle
#            for gpt-oss on multi-step tasks.
CODE_TOOL_MODE=native

# --- AWS Bedrock only (uncomment and use instead of CODE_API_KEY) ------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION_NAME=us-west-2


# -----------------------------------------------------------------------------
# Agent loop                                                      (src/config.py)
# -----------------------------------------------------------------------------

# Directory the agent reads/edits. Locally defaults to the current directory;
# the Docker image sets this to /workspace (the mounted repo) automatically.
# Point it at a REAL repo — running against an empty directory yields a
# "no_action" run with nothing to edit.
# CODE_WORKSPACE=/path/to/your/repo

# Hard cap on model<->tool iterations per task.
CODE_MAX_STEPS=25

# Auto-approve write/edit/run_command (true), or confirm each interactively
# (false). Interactive confirmation only works on a local TTY, not in compose.
# Back-compat shim: when CODE_PERMISSION_MODE is unset, true -> bypass, false -> default.
CODE_AUTO_APPROVE=true

# --- permissions (Phase 4 #6) — see specs/0001-permissions.md ---
# How much to auto-approve. Unset = derived from CODE_AUTO_APPROVE (above).
#   default     - mutating tools need approval (prompt if a human is present, else block)
#   acceptEdits - auto-approve write_file/edit_file; run_command still gated
#   plan        - read-only: every mutating tool is blocked
#   bypass      - auto-approve everything (today's default)
CODE_PERMISSION_MODE=
# Path to a JSON file of allow/ask/deny rules (see permissions.json.example). deny
# ALWAYS wins, even under bypass. Matchers: run_command(rm:*), edit_file(src/**).
CODE_PERMISSIONS_CONFIG=
# Extra dirs the file tools may touch beyond the workspace (os.pathsep- or comma-
# separated). The workspace is always allowed; this only widens the fence.
CODE_ADD_DIRS=

# Print tool activity to stdout as the agent works.
CODE_VERBOSE=true

# --- context compaction (Phase 4) ---
# When the live context exceeds this estimated-token budget, older turns are
# summarized so the model keeps working in a smaller window. This shrinks only
# what the MODEL SEES — the full raw history is still logged (see ROADMAP
# "capture vs context"). 0 disables compaction. Set low (e.g. 800) to force it
# for testing.
CODE_COMPACT_AT_TOKENS=12000
# How many of the most-recent messages to keep verbatim (never summarized).
CODE_COMPACT_KEEP_RECENT=6

# --- subagents (Phase 4) ---
# How deep spawn_agent can nest. 0 = disabled, 1 = one level (top-level agent may
# spawn, its children may not), 2 = children may spawn too, etc. Each subagent runs
# in isolation and is captured as its own (linked) trajectory.
CODE_MAX_SUBAGENT_DEPTH=1

# --- external tools (Phase 4 tool breadth) — OPT-IN egress ---
# Master switch for the web tools. OFF by default to preserve data sovereignty:
# web_fetch / web_search send data OFF this machine. Set true to allow them.
CODE_ENABLE_WEB=false
# BYO search endpoint that web_search POSTs {"query": ...} to, + an optional key.
# Leave empty and web_search reports "not configured".
CODE_SEARCH_URL=
CODE_SEARCH_KEY=

# Connect MCP servers (stdio) listed in this JSON file — their tools appear as
# mcp__<server>__<tool>. Unset = MCP off. See mcp.json.example. The server's
# runtime (node/npx, python, ...) must be installed where openagent-code runs.
CODE_MCP_CONFIG=

# --- cross-session memory (Phase 4 #7) ---
# OFF by default (opt-in): writes a notes file INTO the target repo, and stays off
# for eval so the harness is isolated. On = the `remember` tool is offered and the
# project memory file is loaded into the system prompt at the start of each session.
CODE_MEMORY=false
# Per-project memory file, resolved relative to the workspace.
CODE_MEMORY_FILE=.openagent/memory.md
# Cap on how much memory is loaded into context (keeps the system prompt bounded;
# the most-recent notes are kept).
CODE_MEMORY_MAX_CHARS=4000


# -----------------------------------------------------------------------------
# Training flywheel                                               (src/config.py)
# -----------------------------------------------------------------------------

# Where session JSONL is written. Relative paths resolve against CODE_WORKSPACE,
# so trajectories land in the repo being worked on and persist on the host.
CODE_TRAJECTORY_DIR=trajectories

# Mandated verification = the objective reward signal. The command that proves
# a change works in the TARGET repo, e.g. "pytest -q" or "npm test". Empty skips
# verification (no reward label is recorded for the session).
CODE_VERIFY_COMMAND=

# Which captured view train/convert.py flattens into SFT rows:
#   raw     — the full uncompacted history, every turn (the source of truth). Default.
#   as_sent — what the model actually saw (post-compaction); train the model to
#             work well FROM compacted context.
CODE_SFT_VIEW=raw
