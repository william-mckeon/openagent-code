# =============================================================================
# openagent-code - Docker build-context exclusions
# =============================================================================
#
# Everything listed here is excluded from the `docker build` context. A smaller
# context means faster builds and smaller, leaner images.
#
# CRITICAL: .env must be excluded. Never bake secrets into image layers.
# =============================================================================


# --- Version control --------------------------------------------------------
.git
.gitignore
.gitattributes
.github


# --- Secrets - NEVER bake these into image layers ---------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/


# --- Python build / cache artifacts -----------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build
dist
*.egg-info
.eggs


# --- Virtual environments ---------------------------------------------------
.venv
venv
env
ENV


# --- Captured training data + the mounted workspace (not part of the image) -
trajectories
workspace


# --- IDE / editor -----------------------------------------------------------
.vscode
.idea
*.swp
*.swo
*~


# --- OS noise ---------------------------------------------------------------
.DS_Store
Thumbs.db


# --- Documentation / specs / scripts (keep image lean) ----------------------
# eval/ is intentionally NOT excluded: it ships in the image (see Dockerfile) so
# the harness can run in-container. It's tiny (a few YAML task files).
docs
specs
train
scripts


# --- Compose / orchestration (not part of the image) -----------------------
docker-compose.yml
docker-compose.*.yml


# --- This file itself -------------------------------------------------------
.dockerignore
